OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Momentum integration (optional).
# If unset, the Campaign Studio ↔ Momentum bridge falls back to localhost dev ports.
# In production, point these to your deployed Momentum instance.
NEXT_PUBLIC_MOMENTUM_WEB_URL=http://localhost:3001
NEXT_PUBLIC_MOMENTUM_API_URL=http://localhost:8000
